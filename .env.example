# LLM providers
# OpenRouter — used by the `cerebras` skill (LiteLLM → OpenRouter → Cerebras,
# model openai/gpt-oss-120b). Required for real, fast LLM calls.
OPENROUTER_API_KEY=
# Anthropic API — used by the `legal-template-drafting` skill (optional).
ANTHROPIC_API_KEY=

# Backend
DATABASE_URL=sqlite:///./app/db/pre_legal.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
